<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - E-Ticaret</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-glass">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">E-Ticaret</a>

            <div class="ms-auto d-flex gap-2">
                <a class="btn btn-sm btn-gradient" href="/Products">Ürünler</a>
                <a class="btn btn-sm btn-warm" href="/Cart">🛒 Sepet</a>
                <a class="btn btn-sm btn-outline-light" href="/Account/Login">Giriş</a>
                <a class="btn btn-sm btn-outline-light" href="/Account/Register">Kayıt Ol</a>
            </div>

        </div>
    </nav>

    <main class="container py-5">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
