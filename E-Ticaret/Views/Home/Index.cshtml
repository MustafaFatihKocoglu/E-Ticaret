@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>E-Ticaret | Ana Sayfa</title>

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #0d6efd, #6610f2);
            min-height: 100vh;
        }

        .hero {
            color: white;
            padding: 100px 20px;
            text-align: center;
        }

        .card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>

    <!-- HERO SECTION -->
    <div class="hero">
        <h1 class="display-4 fw-bold">Modern E-Ticaret Sitesi</h1>
        <p class="lead mt-3">
            ASP.NET Core MVC ile geliştirilmiştir
        </p>
        <a href="/Products" class="btn btn-light btn-lg mt-4">
            Ürünleri Keşfet
        </a>
    </div>

    <!-- FEATURES -->
    <div class="container mb-5">
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <h4>🛒 Kolay Alışveriş</h4>
                    <p>Hızlı ve kullanıcı dostu alışveriş deneyimi.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <h4>🔐 Güvenli Sistem</h4>
                    <p>ASP.NET Core altyapısı ile güvenli yapı.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 text-center">
                    <h4>⚡ Hızlı Performans</h4>
                    <p>Modern MVC mimarisiyle yüksek performans.</p>
                </div>
            </div>

        </div>
    </div>

    <!-- FOOTER -->
    <footer class="text-center text-white py-3">
        © 2026 | ASP.NET Core MVC E-Ticaret Projesi
    </footer>

</body>
</html>
